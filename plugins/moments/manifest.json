{
  "id": "com.orangechat.plugin.moments",
  "name": "朋友圈",
  "description": "基于 Supabase 的朋友圈功能，可以发布动态、点赞、评论，查看朋友圈流",
  "version": "1.0.0",
  "author": "OrangeChat",
  "icon": "📸",
  "entry": "main.js",
  "customPageWebView": {
    "entry": "ui/index.html"
  },
  "config": [
    {
      "name": "user_nickname",
      "type": "string",
      "label": "用户昵称",
      "description": "你在朋友圈中显示的昵称",
      "required": true,
      "placeholder": "我的昵称"
    },
    {
      "name": "ai_nickname",
      "type": "string",
      "label": "AI 昵称",
      "description": "AI 在朋友圈中显示的昵称",
      "required": true,
      "placeholder": "AI 的昵称"
    }
  ],
  "tools": [
    {
      "name": "moments_publish",
      "description": "以 AI 的身份发布一条朋友圈动态",
      "parameters": [
        {
          "name": "content",
          "type": "string",
          "required": true,
          "description": "动态文字内容"
        },
        {
          "name": "image_urls",
          "type": "string",
          "required": false,
          "description": "图片URL列表，多个用逗号分隔"
        }
      ]
    },
    {
      "name": "moments_feed",
      "description": "获取朋友圈动态列表，支持分页加载",
      "parameters": [
        {
          "name": "limit",
          "type": "integer",
          "required": false,
          "description": "每次获取条数，默认5"
        },
        {
          "name": "offset",
          "type": "integer",
          "required": false,
          "description": "跳过前面的条数，用于分页加载，默认0"
        }
      ]
    },
    {
      "name": "moments_like",
      "description": "给一条朋友圈动态点赞或取消点赞",
      "parameters": [
        {
          "name": "moment_id",
          "type": "string",
          "required": true,
          "description": "动态ID"
        }
      ]
    },
    {
      "name": "moments_comment",
      "description": "以 AI 身份评论一条朋友圈动态",
      "parameters": [
        {
          "name": "moment_id",
          "type": "string",
          "required": true,
          "description": "动态ID"
        },
        {
          "name": "content",
          "type": "string",
          "required": true,
          "description": "评论内容"
        }
      ]
    }
  ]
}